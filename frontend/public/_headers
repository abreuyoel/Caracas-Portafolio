/*
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Embedder-Policy: unsafe-none
  Alt-Svc: clear

/favicon.ico
  Cache-Control: public, max-age=3600, must-revalidate

/favicon.svg
  Cache-Control: public, max-age=3600, must-revalidate

/icons/*
  Cache-Control: public, max-age=3600, must-revalidate

/manifest.webmanifest
  Cache-Control: public, max-age=3600, must-revalidate
